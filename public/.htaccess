#installpl is my subfolder
DirectoryIndex /medservice/public/index.php 
RewriteEngine on
RewriteBase /medservice
RewriteCond $1 !^(index\.php|images|assets|css|download|js|robots\.txt|favicon\.ico)
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(.*)$ ./public/index.php/$1 [L,QSA]