#--------------------------------------------------------------------
# Medservice — .env template
# Copy to Medservice/.env and fill in per-environment values.
# All connection / URL settings live here (not in App.php / Database.php).
#--------------------------------------------------------------------

CI_ENVIRONMENT = development

# Base URL — MUST end with trailing slash
app.baseURL = 'http://localhost/medservice/public/'

# Database (default)
database.default.hostname = shared_mysql
database.default.database = Amenia
database.default.username = root
database.default.password = changeme
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306

# Database (tests)
database.tests.hostname = shared_mysql
database.tests.database = Amenia
database.tests.username = root
database.tests.password = changeme
database.tests.DBDriver = MySQLi
database.tests.DBPrefix =
database.tests.charset = utf8mb4
database.tests.DBCollat = utf8mb4_general_ci
database.tests.port = 3306

logger.threshold = 9
